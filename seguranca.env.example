# =====================================================
# ARQUIVO DE CONFIGURAÇÃO DE SEGURANÇA
# =====================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para "seguranca.env"
# 2. Preencha COM SEUS VALORES REAIS
# 3. NUNCA commitir seguranca.env no Git
# =====================================================

# CHAVE SECRETA DO FLASK (gerada automaticamente)
# Use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=seu-valor-aleatorio-super-secreto-aqui-minimo-32-caracteres

# AMBIENTE (development ou production)
FLASK_ENV=development

# BANCO DE DADOS
DATABASE_URL=sqlite:///instance/database.db

# CONFIGURAÇÕES DE EMAIL (para notificações e recuperação de senha)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app-especifica

# CONFIGURAÇÕES DE RATE LIMITING
RATELIMIT_ENABLED=true
RATELIMIT_LOGIN_ATTEMPTS=5
RATELIMIT_LOGIN_WINDOW=900

# 2FA (Two-Factor Authentication) - Opcional
TWO_FACTOR_ENABLED=false
OTP_ISSUER_NAME=BattleZone

# SEGURANÇA DE UPLOAD
MAX_UPLOAD_SIZE=16777216
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,bmp,webp

# LOGGING
LOG_TO_FILE=true
LOG_LEVEL=INFO

# NOTIFICAÇÕES SENTRY (Opcional - para produção)
SENTRY_DSN=

# DEBUG MODE (NUNCA deixar true em produção)
DEBUG=false
