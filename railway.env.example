# railway.env.example - Variáveis de ambiente para Railway
# Copie este arquivo para railway.env ou configure diretamente no painel Railway

# ==================== OBRIGATÓRIO ====================
SECRET_KEY=coloque-aqui-uma-chave-secreta-de-32-caracteres

# ==================== BANCO DE DADOS ====================
# Railway cria DATABASE_URL automaticamente quando você adiciona PostgreSQL
# Descomente a linha abaixo se quiser usar PostgreSQL ao invés de auto-detectar
# DATABASE_URL=postgresql://user:password@host:port/database

# ==================== AMBIENTE ====================
FLASK_ENV=production
DEBUG=false

# ==================== EMAIL ====================
# Configure para enviar emails com novos usuários
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=seu.email@gmail.com
MAIL_PASSWORD=sua-app-password

# ==================== SEGURANÇA ====================
RATELIMIT_ENABLED=true
RATELIMIT_LOGIN_ATTEMPTS=5
RATELIMIT_LOGIN_WINDOW=900

# ==================== LOGGING ====================
LOG_TO_FILE=true
LOG_LEVEL=INFO

# ==================== UPLOAD ====================
MAX_UPLOAD_SIZE=16777216

# ==================== 2FA (OPCIONAL) ====================
TWO_FACTOR_ENABLED=false
OTP_ISSUER_NAME=BattleZone
